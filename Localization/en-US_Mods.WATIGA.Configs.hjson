		Label: "[i:1159] Tiki Armor Rework"
		Tooltip: Turns Tiki Armor into a whip focused armor set
	}

	GogglesVanityChange: {
		Label: "[i:37] Goggles into Vanity"
		Tooltip: Turns Goggles into a vanity item
	}

	RainArmorVanityChange: {
		Label: "[i:1136] Rain Armor into Vanity"
		Tooltip: Turns Rain Armor into a vanity set
	}

	PotionChanges: {
		Label: "[i:303] Potion Changes"
		Tooltip: Rebalances several vanilla potions including Ammo Reservation, Archery, Magic Power and Summoning
	}

	ChesterRework: {
		Label: "[i:5098] Chester Rework"
		Tooltip: Chester now opens your safe and works like the Money Trough instead of being a pet
	}

	WoodGreavesChange: {
		Label: "[i:729] Wood Greaves Defense"
		Tooltip: Wood greaves now grant 1 defense
	}

	CoinGunChange: {
		Label: "[i:905] Coin Gun Stats"
		Tooltip: Coin Gun has 1 damage to it has a proper stat readout
	}
}

RecipeTweaksPage: {
	Tooltip: ""

	StarCannonRecipeChange: {
		Label: "[i:197] Star Cannon Recipe Change"
		Tooltip: Star Cannon recipe now uses Illegal Gun Parts instead of a Minishark
	}

	BeetleArmorRecipeChange: {
		Label: "[i:2199] Beetle Armor Recipe Change"
		Tooltip: Beetle Armor recipe no longer includes Turtle Armor but costs 2 more Beetle Husks
	}

	MusketBallRecipe: {
		Label: "[i:97] Musket Ball Recipe Added"
		Tooltip: Musket Balls can now be crafted at an anvil with Iron or Lead Bars
	}
}

MiscPage: {
	Tooltip: ""

	DamageReductionUI: {
		Label: "[i:3224] Damage Reduction Readout"
		Tooltip: Makes hovering over your defense icon shows your damage reduction
	}

	TravellingMerchantExtraSlots: {
		Label: "[i:2222] Travelling Merchant Post-Plantera Slot"
		Tooltip: Increases the Travelling Merchant's base item slots by 1 after defeating plantera
	}

	AmmoLocalImmunityFrames: {
		Label: "[i:47] Vanilla Ammo Uses Local Immunity Frames"
		Tooltip: Makes all vanilla arrows and bullets use local immunity frames
	}

	SoulOfBlight: {
		Label: Soul Of Blight
		Tooltip: ""
	}

	ConsumableUpgradesGlow: {
		Label: "[i:29] Consumable Upgrades Glow"
		Tooltip: Life Crystals, Life Crystal Boulders, Mana Crystals and Life Fruit glow faintly
	}

	KingSlimeSlimeStaffDrop: {
		Label: "[i:1309] King Slime Drop Slime Staff"
		Tooltip: King Slime drops Slime Staff at 25% chance in normal and 33% chance in expert
	}

	SteampunkerOppositeEvilSolutions: {
		Label: "[i:782] Opposite Evil Solution in Graveyard"
		Tooltip: The steampunker now sells the opposite evil biome solution during a Blood Moon or Solar Eclipse if in a graveyard
	}

	GraveyardOppositeEvilMimic: {
		Label: "[i:3016] Opposite Evil Mimic in Graveyard"
		Tooltip: Now spawns the opposite evil mimic if summoned in a graveyard
	}

	FriendlyHeartAndManaStars: {
		Label: "[i:58] Friendly Heart And Mana Stars"
		Tooltip: Players cannot pickup hearts or mana stars if they are full
	}

	FullHealthRespawn: {
		Label: "[i:28] Full Health Respawn"
		Tooltip: Players respawn at full health
	}
}
