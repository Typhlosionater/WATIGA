NewContentPage: {
	Tooltip: ""

	LunaticCultistWeapons: {
		Label: Lunatic Cultist Weapons
		Tooltip: Adds a set of new thematic weapons to Lunatic Cultist's loot pool
	}

	SkeletronWeapons: {
		Label: "[tunatex:WATIGA/Content/SkeletronLoot/Crossbone] Expanded Skeletron Loot"
		Tooltip: Adds a set of new thematic weapons to skeletron's loot pool and tweaks the current pool
	}

	HardmodeOreGuns: {
		Label: "[tunatex:WATIGA/Content/HardmodeOreGuns/PalladiumRevolver] Hardmode Bar Guns"
		Tooltip: Adds a new craftable gun to each of the hardmode bar item sets
	}

	MiscPreHardmodeWeapons: {
		Label: "[tunatex:WATIGA/Content/MiscPreHardmodeWeapons/BloodySceptre] Misc Pre-Hardmode Weapons"
		Tooltip: Adds new pre-hardmode weapons to fit gaps left by vanilla
	}

	ExpertAccessories: {
		Label: "[tunatex:WATIGA/Content/ExpertAccessories/SpellweaveScarf] Expert Accessories"
		Tooltip: Adds new Expert Mode exclusive accessories to the Lunatic Cultist, Betsy, and the Mech Bosses
	}

	FragmentEmblems: {
		Label: "[tunatex:WATIGA/Content/FragmentEmblems/SolarEmblem] Fragment Emblems"
		Tooltip: Adds new celestial event tier emblem upgrades
	}

	GemCharmAccessories: {
		Label: "[tunatex:WATIGA/Content/GemCharms/PrismaticCharm] Gem Charm Accessories"
		Tooltip: Adds a set of new early game accessories crafted from gems
	}

	SummonerHardmodeOreHelmets: {
		Label: "[tunatex:WATIGA/Content/HardmodeOreSummonerHelmets/OrichalcumHat] Hardmode Bar Summoner Helmets"
		Tooltip: Adds a new summoner helmet to each of the early hardmode bar armor sets
	}

	NewAmmoTypes: {
		Label: "[tunatex:WATIGA/Content/NewAmmoTypes/BouncyArrow] New Ammo Types"
		Tooltip: Adds a variety of new bullet and arrow types throughout progression
	}

	NewPotions: {
		Label: "[tunatex:WATIGA/Content/NewPotions/BerserkPotion] New Potions"
		Tooltip: Adds several new potions, filling gaps left by vanilla
	}

	FlinxFurHat: {
		Label: "[tunatex:WATIGA/Content/MiscArmor/FlinxFurHat] Flinx Fur Hat"
		Tooltip: Adds a new helmet to the flinx fur armor set
	}
}

